# Local development environment template.
# Copy to .env and fill in real values.
# .env is gitignored — never commit it.

# SQLAlchemy async URL for Postgres.
# Local dev (docker compose up):
#   postgresql+asyncpg://little_signals:dev_only_password@localhost:5432/little_signals_dev
# Tests use little_signals_test instead of little_signals_dev.
DATABASE_URL=postgresql+asyncpg://little_signals:dev_only_password@localhost:5432/little_signals_dev

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Reported by GET /health. Bump on each release.
APP_VERSION=0.1.0
