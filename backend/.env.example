# Local development environment template.
# Copy to .env and fill in real values.
# .env is gitignored — never commit it.

# SQLAlchemy async URL for Postgres.
# Local dev (docker compose up):
#   postgresql+asyncpg://little_signals:dev_only_password@localhost:5432/little_signals_dev
# Tests use little_signals_test instead of little_signals_dev.
DATABASE_URL=postgresql+asyncpg://little_signals:dev_only_password@localhost:5432/little_signals_dev

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# Reported by GET /health. Bump on each release.
APP_VERSION=0.7.0

# Test database — used by pytest. Apply migrations with:
#   DATABASE_URL=$TEST_DATABASE_URL poetry run alembic upgrade head
TEST_DATABASE_URL=postgresql+asyncpg://little_signals:dev_only_password@localhost:5432/little_signals_test

# Sprint 3 — Supabase auth.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-secret
SUPABASE_JWT_SECRET=replace-with-jwt-secret
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id.apps.googleusercontent.com
